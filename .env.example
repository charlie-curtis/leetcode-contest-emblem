# Required unless you pass ?username= in the URL.
LEETCODE_USERNAME=your_leetcode_username

# Required for authenticated contest history access.
LEETCODE_SESSION=your_leetcode_session_cookie_value

# Optional, but useful when LeetCode requires CSRF validation.
LEETCODE_CSRF_TOKEN=your_csrftoken_cookie_value

# Optional server settings.
PORT=3000
CACHE_TTL_MINUTES=30
THEME=dark
CONTEST_MODE=actual
